{
  "name": "@ferrierepete/mcpshield",
  "version": "0.2.1",
  "description": "Security scanner for MCP (Model Context Protocol) servers — detect supply chain risks, permission overreach, and misconfigurations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcpshield": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/data/*.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "model-context-protocol",
    "supply-chain",
    "ai-security",
    "claude",
    "devsecops"
  ],
  "author": "Peter Ferriere",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferrierepete/mcpshield.git"
  },
  "bugs": {
    "url": "https://github.com/ferrierepete/mcpshield/issues"
  },
  "homepage": "https://github.com/ferrierepete/mcpshield#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^1.2.0"
  }
}
