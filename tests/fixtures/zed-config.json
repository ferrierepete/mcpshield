{
  "context_servers": {
    "github": {
      "command": {
        "path": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_test123"
        }
      }
    },
    "filesystem": {
      "command": {
        "path": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"]
      },
      "settings": {
        "allowed_extensions": [".ts", ".js", ".json"],
        "max_file_size": 1048576
      }
    }
  }
}
