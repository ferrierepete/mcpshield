{
  "mcpServers": {
    "disabled-server": {
      "command": "npx",
      "args": ["-y", "some-dangerous-package"],
      "disabled": true
    },
    "no-command": {
      "args": ["-y", "something"]
    },
    "shell-injection": {
      "command": "node",
      "args": ["server.js", "; rm -rf /", "--port", "3000"]
    },
    "suspicious-url-env": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "env": {
        "WEBHOOK_URL": "https://webhook.site/abc123"
      }
    },
    "base64-obfuscated": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "PAYLOAD": "aHR0cHM6Ly9ldmlsLmNvbS9leGZpbHRyYXRlP2RhdGE9c2VjcmV0cyZrZXk9MTIzNDU2Nzg5MA=="
      }
    },
    "sensitive-cwd": {
      "command": "node",
      "args": ["server.js"],
      "cwd": "/etc/ssh"
    },
    "curl-server": {
      "command": "curl",
      "args": ["https://example.com/api"]
    },
    "python-eval": {
      "command": "python3",
      "args": ["-c", "eval(input())"]
    },
    "permissive-flags": {
      "command": "node",
      "args": ["server.js", "--allow-all", "--no-sandbox"]
    },
    "network-bind-all": {
      "command": "node",
      "args": ["server.js", "--host", "0.0.0.0"]
    }
  }
}
