---
---

<section class="hero" aria-label="Introduction">
  <nav class="nav" aria-label="Primary">
    <a href="/" class="nav-brand">MCPShield</a>
    <div class="nav-links">
      <a href="https://github.com/peterferreira/mcpshield" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.npmjs.com/package/mcpshield" target="_blank" rel="noopener noreferrer">npm</a>
    </div>
  </nav>

  <hr />

  <div class="hero-body">
    <div class="hero-statement reveal">
      <h1 class="hero-title">MCPShield</h1>
      <p class="hero-tagline">
        Scan MCP server configurations<br />
        for security risks before<br />
        they reach your machine.
      </p>
    </div>

    <div class="hero-cta reveal">
      <div class="install-block">
        <span class="install-prompt" aria-hidden="true">$</span>
        <code class="install-cmd">npx mcpshield scan</code>
        <button
          class="copy-btn"
          data-copy="npx mcpshield scan"
          aria-label="Copy install command to clipboard"
        >
          <svg class="copy-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5.5" y="5.5" width="8" height="8" rx="1" />
            <path d="M3 10.5V3a1 1 0 0 1 1-1h7.5" />
          </svg>
          <span class="copy-label" aria-live="polite">copy</span>
        </button>
      </div>
      <div class="hero-secondary">
        <a href="https://github.com/peterferreira/mcpshield" target="_blank" rel="noopener noreferrer" class="github-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      await navigator.clipboard.writeText(text);
      const label = btn.querySelector<HTMLElement>('.copy-label');
      if (label) label.textContent = 'copied';
      setTimeout(() => { if (label) label.textContent = 'copy'; }, 1500);
    });
  });
</script>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-lg) 0;
  }

  .nav-brand {
    font-weight: var(--fw-bold);
    font-size: var(--text-body);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--fw-medium);
  }

  .hero hr {
    margin: 0;
  }

  .hero-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-3xl) 0;
    gap: var(--space-2xl);
  }

  .hero-statement {
    max-width: 42rem;
  }

  .hero-title {
    font-size: var(--text-display);
    font-weight: var(--fw-extrabold);
    line-height: var(--lh-tight);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-xl);
  }

  .hero-tagline {
    font-size: var(--text-headline);
    font-weight: var(--fw-regular);
    line-height: var(--lh-snug);
    color: var(--color-muted);
    max-width: 32ch;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .install-block {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background-color: var(--color-ink);
    color: var(--color-paper);
    padding: var(--space-sm) var(--space-md);
    border-radius: 2px;
    font-size: var(--text-body);
    width: fit-content;
  }

  .install-prompt {
    color: var(--color-faint);
    user-select: none;
  }

  .install-cmd {
    font-family: var(--font-mono);
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-2xs) var(--space-xs);
    margin-left: var(--space-xs);
    border-radius: 2px;
    color: var(--color-faint);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .copy-btn:hover {
    color: var(--color-paper);
  }

  .copy-label {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .hero-secondary {
    display: flex;
    gap: var(--space-lg);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--fw-medium);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .github-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero-body {
      padding: var(--space-2xl) 0;
    }

    .hero-tagline {
      max-width: 100%;
    }

    .install-block {
      width: 100%;
    }
  }
</style>
