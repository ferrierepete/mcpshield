---
const year = new Date().getFullYear();
---

<footer class="footer" aria-label="Site footer">
  <hr />
  <div class="footer-body">
    <div class="footer-primary">
      <span class="footer-brand">MCPShield</span>
      <span class="footer-tagline">Security scanner for MCP servers</span>
    </div>
    <div class="footer-links">
      <a href="https://github.com/peterferreira/mcpshield" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.npmjs.com/package/mcpshield" target="_blank" rel="noopener noreferrer">npm</a>
      <a href="https://github.com/peterferreira/mcpshield/issues" target="_blank" rel="noopener noreferrer">Issues</a>
      <a href="https://github.com/peterferreira/mcpshield/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer">Changelog</a>
    </div>
    <p class="footer-note">Built for developers who take security seriously.</p>
    <p class="footer-copy">&copy; {year} Peter Ferriere. MIT license.</p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .footer-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-primary {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .footer-brand {
    font-weight: var(--fw-bold);
    font-size: var(--text-body);
  }

  .footer-tagline {
    color: var(--color-muted);
    font-size: var(--text-label);
  }

  .footer-links {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--fw-medium);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-note {
    color: var(--color-muted);
    font-size: var(--text-label);
    margin-top: var(--space-sm);
  }

  .footer-copy {
    color: var(--color-faint);
    font-size: var(--text-label);
  }
</style>
