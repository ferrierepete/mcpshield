# MCPShield AI Configuration
# Copy this file to .env and fill in your API key for the provider you want to use.
# Only ONE provider key is needed.

# --- Provider Selection ---
# MCPSHIELD_AI_PROVIDER=openai        # openai | anthropic | gemini
# MCPSHIELD_AI_MODEL=gpt-4o-mini      # override default model for your provider

# --- OpenAI (also works for Groq, Together, Ollama, etc.) ---
# OPENAI_API_KEY=sk-...
# MCPSHIELD_OPENAI_API_KEY=sk-...     # takes priority over OPENAI_API_KEY

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# MCPSHIELD_ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---
# GEMINI_API_KEY=AI...
# GOOGLE_API_KEY=AI...
# MCPSHIELD_GEMINI_API_KEY=AI...

# --- Custom OpenAI-compatible endpoint (Groq, Together, Ollama, etc.) ---
# MCPSHIELD_AI_BASE_URL=http://localhost:11434/v1
